            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{user_service_url}}/api/auth/login",
              "host": ["{{user_service_url}}"],
              "path": ["api", "auth", "login"]
